# ============================================
# NEXA ONE - Environment Variables
# ============================================
# Copia este archivo a .env.local y completa con tus credenciales reales

# ============================================
# SUPABASE (REQUERIDO)
# ============================================
# Obtén estas credenciales en: https://supabase.com/dashboard/project/[tu-proyecto]/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ============================================
# OPENAI (REQUERIDO para IA)
# ============================================
# Obtén tu API key en: https://platform.openai.com/api-keys
# Costo aproximado: $0.01 - $0.03 por generación

OPENAI_API_KEY=sk-proj-tu-openai-key-aqui

# ============================================
# ANTHROPIC / CLAUDE (OPCIONAL)
# ============================================
# Obtén tu API key en: https://console.anthropic.com/
# Solo si quieres usar Claude además de GPT-4

ANTHROPIC_API_KEY=sk-ant-tu-anthropic-key-aqui

# ============================================
# GITHUB OAUTH (REQUERIDO para integración Git)
# ============================================
# Crea una OAuth App en: https://github.com/settings/developers
# Callback URL: https://tu-dominio.com/api/github/callback

GITHUB_CLIENT_ID=Iv1.tu-client-id
GITHUB_CLIENT_SECRET=tu-client-secret-aqui
GITHUB_REDIRECT_URI=https://nexaoneia.com/api/github/callback

# ============================================
# VERCEL (REQUERIDO para deployments)
# ============================================
# Obtén tu token en: https://vercel.com/account/tokens
# Scope: Full Access o Deployment

VERCEL_TOKEN=tu-vercel-token-aqui

# Opcional: Solo si usas Vercel Teams
# VERCEL_TEAM_ID=team_tu-team-id

# ============================================
# SITE CONFIGURATION (REQUERIDO)
# ============================================
# URL principal de tu aplicación

NEXT_PUBLIC_SITE_URL=https://nexaoneia.com

# Dominio base para subdominios (sin https://)
NEXT_PUBLIC_BASE_DOMAIN=nexaoneia.com

# ============================================
# PAYMENT PROVIDERS (OPCIONAL - Para futuro)
# ============================================
# Stripe
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago (LATAM)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# ============================================
# EMAIL (OPCIONAL - Para notificaciones)
# ============================================
# Supabase Auth ya tiene email integrado
# Esto es solo si quieres enviar emails personalizados

# Resend
# RESEND_API_KEY=re_...

# SendGrid
# SENDGRID_API_KEY=SG....

# ============================================
# ANALYTICS (OPCIONAL)
# ============================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (gratis con Vercel)
# Se activa automáticamente, no requiere config

# ============================================
# MONITORING (OPCIONAL)
# ============================================
# Sentry (para error tracking)
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ============================================
# DESARROLLO
# ============================================
# Node Environment (automático en Vercel)
# NODE_ENV=development

# Debug mode
# DEBUG=true

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. NUNCA compartas este archivo con credenciales reales
# 2. Agrega .env.local a .gitignore
# 3. En Vercel, configura las variables en Dashboard → Settings → Environment Variables
# 4. Las variables que empiezan con NEXT_PUBLIC_ son visibles en el cliente
# 5. Las demás son secretas y solo visibles en el servidor
#
# ============================================
# COSTOS ESTIMADOS (por mes)
# ============================================
#
# Supabase Free: $0/mes (hasta 500MB DB + 1GB bandwidth)
# OpenAI API: ~$10-50/mes (depende del uso)
# Vercel Hobby: $0/mes (100GB bandwidth)
# GitHub: $0/mes (repos públicos ilimitados)
# Dominio: ~$10-15/año
#
# TOTAL: ~$10-50/mes (principalmente OpenAI)
#
# ============================================