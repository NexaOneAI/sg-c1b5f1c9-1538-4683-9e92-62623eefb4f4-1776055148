# Supabase (REQUIRED - Already configured in .env.local)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI API (OPTIONAL - For AI code generation)
# Get your API key from: https://platform.openai.com/api-keys
# Uncomment and add your key to enable real AI generation:
# OPENAI_API_KEY=sk-...

# Vercel Deployment (OPTIONAL - For automatic project deployment)
# Get your token from: https://vercel.com/account/tokens
# VERCEL_TOKEN=your_vercel_token
# VERCEL_TEAM_ID=your_team_id (optional, for team deployments)

# Stripe/Mercado Pago (OPTIONAL - For payment processing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Or use Mercado Pago:
# MERCADOPAGO_ACCESS_TOKEN=your_access_token

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000